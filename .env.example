# ===========================================
# Connabis Verification System
# Environment Variables
# ===========================================
# Copy this file to .env and fill in your values
# NEVER commit .env to git

# General
NODE_ENV=production
APP_BASE_URL=https://connabis-verification-system.onrender.com

# Sender email address (must match a verified Resend domain)
FROM_EMAIL="Connabis <no-reply@connabis.com.co>"

# Admin Notification Email (receives verification result alerts)
NOTIFY_EMAIL=connabisco@gmail.com

# Resend (Email Service)
# Get your API key at: https://resend.com/api-keys
# Domain connabis.com.co must be verified in Resend (SPF + DKIM DNS records)
RESEND_API_KEY=re_xxxxxxxxxxxxx

# Shopify (Dev Dashboard App — Client Credentials Grant)
# IMPORTANT: Use the .myshopify.com domain, NOT the custom domain
SHOPIFY_STORE_URL=connabis.myshopify.com
# Client ID and Client Secret from Dev Dashboard → Settings
# The app exchanges these for a short-lived access token (24h) automatically
SHOPIFY_CLIENT_ID=xxxxxxxxxxxxx
SHOPIFY_CLIENT_SECRET=xxxxxxxxxxxxx
# Webhook signing secret (from Settings → Notifications → Webhooks)
SHOPIFY_WEBHOOK_SECRET=xxxxxxxxxxxxx

# Shopify Verification Config (hardcoded in services/shopify.js):
# - Tag: "Verified"
# - Metafield: custom.verified_number (type: number_integer)
# - Sequential numbering starts at 300, auto-increments via GraphQL query

# VeriDocID / SUMA Mexico (Identity Verification)
# API base: https://veridocid.azure-api.net/api/
#
# OAuth credentials (provided by SUMA — used for Bearer token auth)
SUMA_CLIENT_ID=xxxxxxxxxxxxx
SUMA_CLIENT_SECRET=xxxxxxxxxxxxx
#
# Private API key (sk_... prefix — provided by SUMA team)
# Required for createVerification and urlSdk endpoints
# NOTE: This is NOT the public key (pk_...) — ask SUMA for the private/secret key
SUMA_API_KEY=sk_xxxxxxxxxxxxx
