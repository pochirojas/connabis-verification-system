# ===========================================
# Connabis Verification System
# Environment Variables
# ===========================================
# Copy this file to .env and fill in your values
# NEVER commit .env to git

# General
NODE_ENV=development
APP_BASE_URL=http://localhost:3000

# Admin Notification Email
NOTIFY_EMAIL=connabisco@gmail.com

# Resend (Email Service)
# Get your API key at: https://resend.com/api-keys
# Domain must be verified: connabis.com.co
RESEND_API_KEY=re_xxxxxxxxxxxxx

# Shopify
# Store domain (without https://)
SHOPIFY_STORE_URL=connabis.myshopify.com
# Admin API access token (from Shopify Partners or Admin > Apps > Develop Apps)
SHOPIFY_API_KEY=shpat_xxxxxxxxxxxxx
# API secret key
SHOPIFY_API_SECRET=shpss_xxxxxxxxxxxxx
# Webhook signing secret (from Settings > Notifications > Webhooks)
SHOPIFY_WEBHOOK_SECRET=xxxxxxxxxxxxx

# Shopify Verification Metafield
# These must match your existing metafield definition in Shopify
# Find in: Shopify Admin → Settings → Custom data → Customers
VERIFIED_METAFIELD_NAMESPACE=custom
VERIFIED_METAFIELD_KEY=verified_number

# SUMA Mexico (VeriDocID)
# API base URL
SUMA_BASE_URL=https://api.sumamexico.com
# OAuth client credentials (from your SUMA dashboard)
SUMA_CLIENT_ID=xxxxxxxxxxxxx
SUMA_CLIENT_SECRET=xxxxxxxxxxxxx
